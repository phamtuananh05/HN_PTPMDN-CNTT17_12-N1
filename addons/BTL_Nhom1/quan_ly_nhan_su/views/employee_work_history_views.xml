<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_btl_hr_work_history_tree" model="ir.ui.view">
        <field name="name">btl.hr.work.history.tree</field>
        <field name="model">btl.hr.work.history</field>
        <field name="arch" type="xml">
            <tree>
                <field name="employee_id"/>
                <field name="company_name"/>
                <field name="position"/>
                <field name="date_start"/>
                <field name="date_end"/>
            </tree>
        </field>
    </record>

    <record id="view_btl_hr_work_history_form" model="ir.ui.view">
        <field name="name">btl.hr.work.history.form</field>
        <field name="model">btl.hr.work.history</field>
        <field name="arch" type="xml">
            <form string="Qua trinh cong tac">
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="company_name"/>
                            <field name="position"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_btl_hr_work_history" model="ir.actions.act_window">
        <field name="name">Qua trinh cong tac</field>
        <field name="res_model">btl.hr.work.history</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>