<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_btl_hr_dashboard_form" model="ir.ui.view">
        <field name="name">btl.hr.dashboard.form</field>
        <field name="model">btl.hr.dashboard</field>
        <field name="arch" type="xml">
            <form string="Dashboard nhân sự" create="0" delete="0">
                <sheet>
                    <div class="oe_title">
                        <h1>Dashboard Quản lý nhân sự</h1>
                    </div>

                    <group col="5">
                        <button name="action_open_employees" string="Tổng nhân viên" type="object" class="oe_stat_button" icon="fa-users">
                            <field name="total_employee" widget="statinfo"/>
                        </button>
                        <button name="action_open_departments" string="Phòng ban" type="object" class="oe_stat_button" icon="fa-sitemap">
                            <field name="total_department" widget="statinfo"/>
                        </button>
                        <button name="action_open_my_profile" string="Hồ sơ của tôi" type="object" class="oe_stat_button" icon="fa-user">
                            <field name="my_profile" widget="statinfo"/>
                        </button>
                        <button name="action_open_family" string="Thân nhân" type="object" class="oe_stat_button" icon="fa-users">
                            <field name="total_family" widget="statinfo"/>
                        </button>
                        <button name="action_open_work_history" string="QT công tác" type="object" class="oe_stat_button" icon="fa-briefcase">
                            <field name="total_work_history" widget="statinfo"/>
                        </button>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_btl_hr_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">btl.hr.dashboard</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="btl_hr_dashboard_main"/>
        <field name="view_id" ref="view_btl_hr_dashboard_form"/>
        <field name="target">current</field>
    </record>
</odoo>