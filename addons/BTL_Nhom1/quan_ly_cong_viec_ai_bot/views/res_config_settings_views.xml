<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_btl_ai_bot" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.btl.telegram.bot</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="90"/>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="BTL Telegram Bot" string="BTL Telegram Bot">
                    <h2>BTL Telegram Bot</h2>
                    <div class="row mt16 o_settings_container">

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="telegram_bot_token"/>
                                <div class="text-muted">
                                    Cau hinh Telegram Bot de gui thong bao follow-up va cong viec qua han.
                                </div>
                                <div class="content-group mt16">
                                    <field name="telegram_bot_token" password="True"/>
                                    <field name="telegram_chat_id"/>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>