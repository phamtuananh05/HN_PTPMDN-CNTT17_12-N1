<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_form_inherit_customer_button" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.customer.button</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="priority">30</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_btl_customers" type="object" class="oe_stat_button" icon="fa-users">
                    <field name="btl_customer_count" string="Khach hang" widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>