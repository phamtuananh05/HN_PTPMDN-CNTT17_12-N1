                </sheet>
            </form>
        </field>
    </record>

    <record id="action_btl_task_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">btl.task.dashboard</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="btl_task_dashboard_main"/>
        <field name="view_id" ref="view_btl_task_dashboard_form"/>
        <field name="target">current</field>
    </record>
