<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_btl_task_stage_tree" model="ir.ui.view">
        <field name="name">btl.task.stage.tree</field>
        <field name="model">btl.task.stage</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence"/>
                <field name="name"/>
                <field name="code"/>
                <field name="is_done"/>
                <field name="fold"/>
            </tree>
        </field>
    </record>

    <record id="view_btl_task_stage_form" model="ir.ui.view">
        <field name="name">btl.task.stage.form</field>
        <field name="model">btl.task.stage</field>
        <field name="arch" type="xml">
            <form string="Tien trinh cong viec">
                <sheet>
                    <group>
                        <field name="sequence"/>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="is_done"/>
                        <field name="fold"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_btl_task_stage" model="ir.actions.act_window">
        <field name="name">Tien trinh</field>
        <field name="res_model">btl.task.stage</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>