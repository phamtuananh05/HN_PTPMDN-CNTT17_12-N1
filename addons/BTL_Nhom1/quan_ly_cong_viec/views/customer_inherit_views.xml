<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_btl_customer_form_inherit_task_button" model="ir.ui.view">
        <field name="name">btl.customer.form.inherit.task.button</field>
        <field name="model">btl.customer</field>
        <field name="inherit_id" ref="quan_ly_khach_hang.view_btl_customer_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_tasks" type="object" class="oe_stat_button" icon="fa-tasks">
                    <field name="task_count" string="Cong viec" widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>